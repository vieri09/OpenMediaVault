# ───────────────────────────────────────────────────────────────
# OpenMedia configuration
# Copy this file to ".env" (at the repo root) and edit the values.
# The server reads these on startup.
# ───────────────────────────────────────────────────────────────

# REQUIRED: absolute (or relative) path to the folder that contains your music.
# The server scans this folder recursively for audio files.
# Example (macOS/Linux):  /home/me/Music
# Example (Windows):      C:\Users\me\Music
MUSIC_LIBRARY_PATH=./music

# Port the backend API (and, in production, the whole app) listens on.
APP_PORT=3000

# Where the metadata cache (SQLite) is stored. Defaults to ./data/library.db
DATABASE_PATH=./data/library.db

# Comma-separated list of extra extensions to treat as audio (without the dot).
# The common formats below are always supported; add rare ones here if needed.
# EXTRA_AUDIO_EXTENSIONS=

# Set to "true" to increase log verbosity while scanning / serving.
LOG_LEVEL=info
